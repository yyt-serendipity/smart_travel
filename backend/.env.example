# Copy this file to backend/.env and fill in your local secrets.
DEBUG=true
SECRET_KEY=
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

DB_ENGINE=mysql
DB_NAME=smart_travel
DB_USER=root
DB_PASSWORD=123456
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=smart-travel-yt
OSS_REGION=cn-chengdu
OSS_ENDPOINT=https://oss-cn-chengdu.aliyuncs.com
OSS_MEDIA_PREFIX=media
OSS_SIGN_URL_EXPIRE_SECONDS=315360000

LLM_PROVIDER=qwen
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen2.5-14b-instruct
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_TIMEOUT=25

AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_REQUEST_TIMEOUT=8
